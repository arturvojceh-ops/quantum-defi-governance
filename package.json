{
  "name": "quantum-defi-governance",
  "version": "1.0.0",
  "description": "Quantum-Enhanced DeFi Governance Protocol with Post-Quantum Cryptography",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:security": "npm run test:security:contracts && npm run test:security:frontend",
    "test:security:contracts": "forge test --match-test testSecurity -vv",
    "test:security:frontend": "npm run test:unit",
    "compile": "forge build",
    "compile:watch": "forge build --watch",
    "deploy:local": "forge script script/Deploy.s.sol --rpc-url http://127.0.0.1:8545 --broadcast",
    "deploy:goerli": "forge script script/Deploy.s.sol --rpc-url goerli --broadcast --verify",
    "deploy:sepolia": "forge script script/Deploy.s.sol --rpc-url sepolia --broadcast --verify",
    "deploy:mainnet": "forge script script/Deploy.s.sol --rpc-url mainnet --broadcast --verify --slow",
    "verify": "forge verify-contract",
    "gas-report": "forge test --gas-report",
    "coverage": "forge coverage --report lcov",
    "snapshot": "forge snapshot",
    "security:slither": "slither . --filter naming_convention,external-function,low-level-calls",
    "security:mythril": "myth analyze .",
    "security:audit": "npm audit",
    "security:check": "npm run security:slither && npm run security:mythril && npm run security:audit",
    "build:wasm": "wasm-pack build --target web --out-dir pkg",
    "test:wasm": "wasm-pack test --node",
    "deploy:vercel": "vercel --prod",
    "deploy:cf": "wrangler publish",
    "docker:build": "docker build -t quantum-defi-governance .",
    "docker:run": "docker run -p 3000:3000 quantum-defi-governance",
    "k8s:deploy": "kubectl apply -f k8s/",
    "k8s:delete": "kubectl delete -f k8s/",
    "monitoring:setup": "helm install monitoring ./charts/monitoring",
    "monitoring:delete": "helm uninstall monitoring",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:serve": "vitepress serve docs",
    "prepare": "husky install",
    "pre-commit": "lint-staged",
    "postinstall": "forge install"
  },
  "keywords": [
    "blockchain",
    "defi",
    "governance",
    "quantum",
    "post-quantum",
    "zero-knowledge",
    "smart-contracts",
    "ethereum",
    "solidity",
    "rust",
    "webassembly",
    "nextjs",
    "typescript",
    "security",
    "cryptography"
  ],
  "author": "Artur Vojceh <artur.vojceh@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arturvojceh-ops/quantum-defi-governance.git"
  },
